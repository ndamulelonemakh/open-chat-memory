# ============================================================================
# Open Chat Memory - Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your actual values
# Never commit .env to version control!
# ============================================================================

# ----------------------------------------------------------------------------
# OpenAI Configuration (Required for Mem0 LLM features)
# ----------------------------------------------------------------------------
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...your-key-here...

# ----------------------------------------------------------------------------
# Mem0 LLM Configuration
# ----------------------------------------------------------------------------
# LLM model for memory processing (default: gpt-5-nano)
# Options: gpt-5-nano, gpt-5-mini, gpt-5, gpt-4o-mini, gpt-4o
MEMORY_LLM_MODEL=gpt-5-nano

# Embedding model for semantic search (default: all-MiniLM-L6-v2)
# HuggingFace sentence-transformers model name
MEMORY_EMBED_MODEL=all-MiniLM-L6-v2

# ----------------------------------------------------------------------------
# Qdrant Vector Store Configuration
# ----------------------------------------------------------------------------
# Collection name for storing conversation embeddings
QDRANT_COLLECTION=openchatmemory

# Option 1: Local Qdrant (via Docker)
# Leave QDRANT_URL empty to use local file-based storage at ./data/qdrant_data
# QDRANT_URL=
# QDRANT_HOST=
# QDRANT_PORT=

# Option 2: Remote Qdrant instance
# Uncomment and configure if using a remote Qdrant server
# QDRANT_URL=https://your-qdrant-instance.example.com:443
# QDRANT_HOST=your-qdrant-instance.example.com
# QDRANT_PORT=6333
# QDRANT_API_KEY=your-qdrant-api-key

# ----------------------------------------------------------------------------
# Neo4j Graph Store Configuration (Optional)
# ----------------------------------------------------------------------------
# Neo4j enables graph-based memory relationships
# Leave empty to disable graph store features

# Neo4j connection URL (omit to disable)
# NEO4J_URL=neo4j://localhost:7687
# NEO4J_URL=neo4j+s://your-aura-instance.neo4j.io:7687

# Neo4j credentials
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=your-secure-password
# NEO4J_DATABASE=mem0

# ----------------------------------------------------------------------------
# PostgreSQL Configuration (for db load command)
# ----------------------------------------------------------------------------
# Full connection string for loading messages to PostgreSQL
# Format: postgresql://username:password@host:port/database
# DATABASE_URL=postgresql://user:password@localhost:5432/chatmemory

# ----------------------------------------------------------------------------
# Testing & CI Configuration (Optional)
# ----------------------------------------------------------------------------


# ----------------------------------------------------------------------------
# Quick Start Examples
# ----------------------------------------------------------------------------
# 1. Minimal setup (local Qdrant, no graph store):
#    OPENAI_API_KEY=sk-...
#
# 2. Full setup with remote services:
#    OPENAI_API_KEY=sk-...
#    QDRANT_URL=https://qdrant.example.com:443
#    QDRANT_API_KEY=your-key
#    NEO4J_URL=neo4j://localhost:7687
#    NEO4J_PASSWORD=password
#    DATABASE_URL=postgresql://localhost/chatdb
#
# 3. Docker-based local development:
#    docker run -d -p 6333:6333 qdrant/qdrant
#    docker run -d -p 7687:7687 -e NEO4J_AUTH=neo4j/testpass neo4j
#    OPENAI_API_KEY=sk-...
#    NEO4J_URL=neo4j://localhost:7687
#    NEO4J_PASSWORD=testpass
# ============================================================================
